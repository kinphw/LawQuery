{
  "name": "LawQuery",
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.1",
    "@types/nodemailer": "^8.0.0",
    "concurrently": "^9.1.2",
    "sass": "^1.87.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3",
    "webpack": "^5.99.5",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.1"
  },
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "watch": "webpack --watch --config webpack.config.js",
    "typecheck:watch": "tsc --noEmit --watch",
    "predev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/kill-stale.ps1",
    "dev": "concurrently \"npm:watch\" \"npm run dev:backend\" \"npm run scss:watch\"",
    "dev:backend": "ts-node-dev --respawn --transpile-only src/backend/ts/index.ts",
    "dev:server": "webpack serve --config webpack.config.js",
    "scss:watch": "sass --watch assets/scss/style.scss:assets/css/style.css",
    "predev:full": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/kill-stale.ps1",
    "dev:full": "concurrently \"npm run dev:server\" \"npm run dev:backend\" \"npm run typecheck:watch\" \"npm run scss:watch\""
  },
  "dependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/diff-match-patch": "^1.0.36",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^4.17.21",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "diff-match-patch": "^1.0.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.14.0",
    "nodemailer": "^8.0.10",
    "pm2": "^6.0.5"
  }
}
